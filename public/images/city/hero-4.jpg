y":"CA"}},{"@type":"HomeAndConstructionBusiness","@id":"https://builtbybrio.com/#organization","name":"BRIO Construction","url":"https://builtbybrio.com","sameAs":["https://www.facebook.com/people/BRIO-Construction/61574283754676/"],"email":"info@builtbybrio.com","address":{"@type":"PostalAddress","streetAddress":"#102 - 267 Esplanade W","addressLocality":"North Vancouver","addressRegion":"BC","postalCode":"V7M1A5","addressCountry":"CA"},"logo":{"@type":"ImageObject","@id":"https://builtbybrio.com/#logo","url":"https://builtbybrio.com/wp-content/uploads/2025/03/Built-By-Brio-ICON-scaled.jpg","contentUrl":"https://builtbybrio.com/wp-content/uploads/2025/03/Built-By-Brio-ICON-scaled.jpg","caption":"BRIO Construction","inLanguage":"en-US","width":"2560","height":"2560"},"openingHours":["Monday,Tuesday,Wednesday,Thursday,Friday,Saturday,Sunday 09:00-18:00"],"description":"\"BRIO is a full-service construction company specializing in custom home building, remodeling, and commercial construction. Based on a foundation of integrity and craftsmanship, we bring innovative solutions to homeowners and businesses throughout the North Shore area, Vancouver, Richmond, New Westminster, Burnaby, Squamish, and Lions Bay. Our dedicated team focuses on quality, efficiency, and personalized service\u2014ensuring your project is completed on time and within budget. From comprehensive design-build services to remodeling kitchens and bathrooms, BRIO transforms spaces with unmatched precision and attention to detail. Discover how our passion for excellence can elevate your next construction project\u2014contact us today for a consultation.\"","legalName":"BRIO Construction","location":{"@id":"https://builtbybrio.com/#place"},"image":{"@id":"https://builtbybrio.com/#logo"},"telephone":"+1 -604-260-6691"},{"@type":"WebSite","@id":"https://builtbybrio.com/#website","url":"https://builtbybrio.com","name":"BRIO Construction","publisher":{"@id":"https://builtbybrio.com/#organization"},"inLanguag